# Copy to ../.env or docker/.env for local use. Never commit real secrets.
TZ=Asia/Shanghai

# PostgreSQL
POSTGRES_DB=FoodMate
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DB_URL=jdbc:postgresql://localhost:5432/FoodMate
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis
REDIS_PASSWORD=foodmate-redis-change-me
REDIS_PORT=6379
REDIS_URL=redis://:foodmate-redis-change-me@localhost:6379

# MinIO (private bucket)
MINIO_ROOT_USER=foodmate-local
MINIO_ROOT_PASSWORD=foodmate-minio-change-me
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=foodmate-local
MINIO_SECRET_KEY=foodmate-minio-change-me
MINIO_BUCKET=foodmate-private
MINIO_REGION=us-east-1
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PRESIGN_TTL_SECONDS=300
